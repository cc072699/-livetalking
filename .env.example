# =============================================================================
#  LiveTalking 环境变量配置
#  复制此文件为 .env 并填入实际值:  cp .env.example .env
# =============================================================================

# ─── 应用启动参数（可通过环境变量覆盖，无需修改 Dockerfile）────────────────
MODEL=wav2lip                    # 数字人模型: wav2lip / musetalk / ultralight
AVATAR_ID=cc3                    # 形象ID（对应 data/avatars/ 下的目录名）
TTS=qwentts                      # TTS引擎: qwentts / edgetts / dashscopetts / tencent / doubao / azuretts / gpt-sovits / cosyvoice / fishtts
REF_FILE=Cherry                  # TTS音色名或参考音频文件（qwentts: Cherry/Ethan）
REF_TEXT=                        # 参考文本（部分TTS需要）
TTS_SPEED=1.0                    # TTS语速: 1.0正常, <1慢, >1快
QWEN_TTS_MODEL=qwen-tts-realtime-latest  # Qwen TTS 模型名
TRANSPORT=webrtc                 # 传输方式: webrtc / rtcpush / rtmp / virtualcam
MAX_SESSION=1                    # 最大并发会话数
BATCH_SIZE=16                    # 推理批大小 (V100 16GB 建议: wav2lip=16, musetalk=8)
SUBTITLE=True                    # 是否显示字幕
SUBTITLE_SIZE=1.0                # 字幕字号倍率
# GPU 设备选择 (docker-compose 中配置)
# NVIDIA_VISIBLE_DEVICES=1       # 使用的GPU编号，1/2/3 空闲，0 被 ComfyUI 占用
# MODELRES=192                   # 模型分辨率
# MODELFILE=                     # 自定义模型文件路径
# TTS_SERVER=http://127.0.0.1:9880  # 外部TTS服务地址（gpt-sovits/cosyvoice/fishtts等需要）
# PUSH_URL=                      # RTMP/RTCPush 推流地址
# CUSTOMVIDEO_CONFIG=            # 自定义动作编排JSON路径
# EXTRA_ARGS=                    # 附加命令行参数（高级用法）

# ─── LLM 配置 - 商汤科技 SenseNova ──────────────────────────────────────
SENSNOVA_API_KEY=xxxxxxxx
SENSNOVA_BASE_URL=https://token.sensenova.cn/v1
SENSNOVA_MODEL=deepseek-v4-flash
# LLM提供商选择: sensenova / dashscope
LLM_PROVIDER=sensenova

# ─── LLM 配置 - 阿里云 DashScope（同时用于 QwenTTS / DashScopeTTS）──────
DASHSCOPE_API_KEY=xxxxxxxx
DASHSCOPE_MODEL=qwen-plus

# ─── 腾讯云 TTS ─────────────────────────────────────────────────────────
# TENCENT_APPID=xxxxxxxx
# TENCENT_SECRET_KEY=xxxxxxxx
# TENCENT_SECRET_ID=xxxxxxxx

# ─── 字节跳动 豆包 TTS ──────────────────────────────────────────────────
# DOUBAO_APPID=xxxxxxxx
# DOUBAO_TOKEN=xxxxxxxx

# ─── Azure TTS ──────────────────────────────────────────────────────────
# AZURE_SPEECH_KEY=xxxxxxxx
# AZURE_TTS_REGION=eastasia
